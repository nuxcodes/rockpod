#-----------------------------------------------#
#	Search Index
#	----------------------
#	$FL - Font-loading
#	$VD - Viewport Declarations
#	$SB - Status Bar Logic
#	$ME - Menu Engine
#	$SE - Scroll Engine
#	$WE - Widget Engine
#	$US - USB Screen Logic
#	$SD - System Dialog Box
#	$QS - Quickscreen Engine
#	----------------------
#
# need to flush the background and foreground, or the previous screen's background remains.
%V(0,0,-,-,-)%VB
%V(0,0,-,-,-)
#
#--- Font Pre-loading ---# $FL
#
%Fl(3,22-LeagueSpartan-Bold.fnt) # used for time and large Text
%Fl(4,18-LeagueSpartan-Medium.fnt) # subtext font
%Fl(5,../wps/Themify_2/16-LeagueSpartan-SemiBold.fnt)# battery icon font
%Fl(6,../wps/Themify_2/UI_Vectors.fnt) # ui drawing cectors
%Fl(7,../wps/Themify_2/Blank_Font.fnt,5) # blank font for default quickscreen supression
%Fl(8,../wps/Themify_2/14x13_Compacticons.fnt,120) # vector icons for menus, status bar etc.
%Fl(9,../wps/Themify_2/Graphics_Font.fnt) # vector icons 
#
#--- END ---#
#

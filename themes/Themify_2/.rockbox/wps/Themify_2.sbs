%Vl(No_Scroll_Menu_No_Icons,0,0,314,30,6)%?if(%LT,=,%Sx([By album]))<%?Lc<CMMMMMMMMMMND|%Vs(invert)I%aRJ>>%?and(%if(%LT,=,%Sx([All tracks])),%if(%LN,=,1))<%?Lc<CMMMMMMMMMMND|%Vs(invert)I%aRJ>|%?if(%LT,=,%Sx([All tracks]))<%?Lc<EMMMMMMMMMMNF|%Vs(invert)>>>%?if(%LT,=,%Sx([Random]))<%?Lc<%?if(%LT(1,nowrap),=,%Sx([Untagged]))<E|G>MMMMMMMMMMN%?if(%LT(1,nowrap),!=,%Sx([Untagged]))<H|F>|%?if(%LT(1,nowrap),!=,%Sx([Untagged]))<%Vs(invert)KQQQQQQQQQQRL|%Vs(invert)>>>%?if(%LT,=,%Sx([Untagged]))<%?Lc<GMMMMMMMMMMNH|%Vs(invert)KQQQQQQQQQQRL>>%?if(%LT,!=,%Sx([By album]))<%?if(%LT,!=,%Sx([All tracks]))<%?if(%LT,!=,%Sx([Random]))<%?if(%LT,!=,%Sx([Untagged]))<%?Lc<%Vs(invert)A%aRB>>>>>
